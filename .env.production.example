# Production environment variables template.
# Copy this file to `.env` and fill in real values.
#
#   cp .env.production.example .env
#
# NEVER commit the real .env to source control (.gitignore excludes it).

# ==== REQUIRED — generate with: ================================================
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================
# Used to sign JWTs. Changing this invalidates all existing user sessions.
JWT_SECRET=

# Used to encrypt stored database connection passwords (AES).
# Changing this makes every saved connection password unreadable.
ENCRYPTION_KEY=

# ==== Server =================================================================
# Where the SQLite file lives, relative to the project root.
DB_PATH=./data/dbwiki.sqlite3

# Port Express binds to. Nginx reverse-proxies to this.
PORT=3000

# Public origin of the frontend. Used by CORS allow-list in production.
# Must match the URL the browser uses (https only in production).
CLIENT_URL=https://dbwiki.example.com

# Toggles production behaviour: serves client/dist statically, enables
# stricter CORS, suppresses verbose dev error pages.
NODE_ENV=production
