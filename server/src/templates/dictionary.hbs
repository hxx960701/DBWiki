<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{projectName}} - Data Dictionary</title>
  <style>
    /* ========== Reset & Base ========== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-primary: #1a56db;
      --color-primary-light: #e8effc;
      --color-bg: #f8fafc;
      --color-surface: #ffffff;
      --color-border: #e2e8f0;
      --color-text: #1e293b;
      --color-text-muted: #64748b;
      --color-pk: #2563eb;
      --color-pk-bg: #eff6ff;
      --color-fk: #16a34a;
      --color-fk-bg: #f0fdf4;
      --color-uni: #ea580c;
      --color-uni-bg: #fff7ed;
      --color-idx: #7c3aed;
      --color-idx-bg: #f5f3ff;
      --radius: 8px;
      --shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
      font-size: 14px;
    }

    a { color: var(--color-primary); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ========== Layout ========== */
    .container { max-width: 1100px; margin: 0 auto; padding: 24px 32px; }

    /* ========== Header ========== */
    .header {
      background: linear-gradient(135deg, #1e3a5f 0%, #1a56db 100%);
      color: #fff;
      padding: 40px 32px 32px;
      border-radius: 0 0 var(--radius) var(--radius);
      margin-bottom: 32px;
    }
    .header h1 { font-size: 28px; font-weight: 700; margin-bottom: 4px; }
    .header .subtitle { font-size: 15px; opacity: .85; margin-bottom: 20px; }
    .header-meta {
      display: flex; flex-wrap: wrap; gap: 24px;
      font-size: 13px; opacity: .9;
    }
    .header-meta span { display: inline-flex; align-items: center; gap: 6px; }
    .header-meta .label { opacity: .7; }

    /* ========== Stats Bar ========== */
    .stats-bar {
      display: flex; gap: 16px; margin-bottom: 32px; flex-wrap: wrap;
    }
    .stat-card {
      flex: 1; min-width: 140px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 16px 20px;
      box-shadow: var(--shadow);
      text-align: center;
    }
    .stat-card .stat-value { font-size: 28px; font-weight: 700; color: var(--color-primary); }
    .stat-card .stat-label { font-size: 12px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: .5px; margin-top: 2px; }

    /* ========== Table of Contents ========== */
    .toc {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin-bottom: 32px;
      box-shadow: var(--shadow);
    }
    .toc h2 { font-size: 16px; font-weight: 600; margin-bottom: 14px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: .5px; }
    .toc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 6px 24px;
    }
    .toc-item {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 0;
      font-size: 13px;
    }
    .toc-item .toc-idx {
      color: var(--color-text-muted);
      font-size: 11px;
      font-weight: 600;
      min-width: 24px;
      text-align: right;
    }
    .toc-item .toc-cols {
      margin-left: auto;
      font-size: 11px;
      color: var(--color-text-muted);
      background: var(--color-bg);
      padding: 1px 8px;
      border-radius: 10px;
    }

    /* ========== Table Section ========== */
    .table-section {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      margin-bottom: 24px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .table-header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
    }
    .table-header h3 {
      font-size: 17px;
      font-weight: 700;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }
    .table-badge {
      font-size: 11px;
      padding: 2px 10px;
      border-radius: 10px;
      font-weight: 600;
    }
    .badge-engine { background: #f1f5f9; color: #475569; }
    .badge-rows { background: #f1f5f9; color: #475569; }
    .table-comment {
      width: 100%;
      font-size: 13px;
      color: var(--color-text-muted);
      margin-top: 2px;
    }
    .table-comment.custom {
      color: var(--color-primary);
      font-style: italic;
    }

    /* ========== Data Table ========== */
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .data-table thead th {
      background: #f8fafc;
      padding: 10px 14px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--color-text-muted);
      border-bottom: 2px solid var(--color-border);
      white-space: nowrap;
    }
    .data-table tbody td {
      padding: 9px 14px;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: top;
    }
    .data-table tbody tr:hover { background: #fafbfd; }
    .data-table tbody tr:last-child td { border-bottom: none; }

    .col-name {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-weight: 600;
      color: var(--color-text);
    }
    .col-type {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 12px;
      color: #7c3aed;
    }
    .col-nullable { font-size: 12px; }
    .col-nullable.yes { color: #16a34a; }
    .col-nullable.no { color: #dc2626; font-weight: 600; }

    /* ========== Key Badges ========== */
    .key-badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      letter-spacing: .3px;
      line-height: 1.6;
    }
    .key-pri { background: var(--color-pk-bg); color: var(--color-pk); border: 1px solid #bfdbfe; }
    .key-foreign { background: var(--color-fk-bg); color: var(--color-fk); border: 1px solid #bbf7d0; }
    .key-uni { background: var(--color-uni-bg); color: var(--color-uni); border: 1px solid #fed7aa; }
    .key-mul, .key-idx { background: var(--color-idx-bg); color: var(--color-idx); border: 1px solid #ddd6fe; }

    .col-comment { font-size: 12px; color: var(--color-text-muted); max-width: 300px; }
    .col-custom-comment { font-size: 12px; color: var(--color-primary); font-style: italic; max-width: 300px; }

    .col-default {
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 12px;
      color: var(--color-text-muted);
    }

    /* ========== Tags ========== */
    .tag {
      display: inline-block;
      font-size: 10px;
      padding: 1px 7px;
      border-radius: 3px;
      background: #f1f5f9;
      color: #475569;
      margin-right: 3px;
      margin-bottom: 2px;
    }

    /* ========== Indexes Section ========== */
    .indexes-section {
      padding: 14px 24px;
      border-top: 1px solid var(--color-border);
      background: #fafbfd;
    }
    .indexes-section h4 {
      font-size: 12px; font-weight: 600; color: var(--color-text-muted);
      text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px;
    }
    .index-item {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; padding: 4px 10px; margin: 2px 4px 2px 0;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
    }
    .index-name { font-weight: 600; font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace; }
    .index-type { color: var(--color-text-muted); font-size: 11px; }
    .index-cols { color: var(--color-primary); font-size: 11px; }
    .index-unique {
      font-size: 9px; font-weight: 700;
      background: var(--color-uni-bg); color: var(--color-uni);
      padding: 1px 5px; border-radius: 3px;
    }

    /* ========== Procedures ========== */
    .proc-section {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      margin-bottom: 24px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .proc-header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
    }
    .proc-header h3 {
      font-size: 17px;
      font-weight: 700;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }
    .badge-proc { background: #eef2ff; color: #4338ca; }
    .badge-func { background: #ecfdf5; color: #047857; }
    .proc-meta {
      font-size: 12px;
      color: var(--color-text-muted);
      margin-left: 8px;
    }
    .proc-body { padding: 14px 24px; }
    .proc-body h4 {
      font-size: 12px; font-weight: 600; color: var(--color-text-muted);
      text-transform: uppercase; letter-spacing: .5px; margin: 12px 0 8px;
    }
    .proc-definition {
      background: #f8fafc;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 12px 14px;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 12px;
      line-height: 1.5;
      white-space: pre-wrap;
      max-height: 480px;
      overflow: auto;
    }
    .proc-params {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .proc-params thead th {
      background: #f8fafc;
      padding: 6px 12px;
      text-align: left;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--color-text-muted);
      border-bottom: 1px solid var(--color-border);
    }
    .proc-params tbody td {
      padding: 6px 12px;
      border-bottom: 1px solid #f1f5f9;
    }
    .mode-IN { background: #eff6ff; color: #2563eb; }
    .mode-OUT { background: #fff7ed; color: #ea580c; }
    .mode-INOUT { background: #f5f3ff; color: #7c3aed; }

    /* ========== Back to Top ========== */
    .back-top {
      display: inline-block;
      font-size: 11px;
      color: var(--color-text-muted);
      margin-left: auto;
    }
    .back-top:hover { color: var(--color-primary); text-decoration: none; }

    /* ========== Footer ========== */
    .footer {
      text-align: center;
      padding: 24px;
      font-size: 12px;
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
      margin-top: 40px;
    }

    /* ========== Print Styles ========== */
    @media print {
      body { background: #fff; font-size: 11px; }
      .container { max-width: 100%; padding: 0 16px; }
      .header { background: #1a56db !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .stats-bar { break-inside: avoid; }
      .stat-card { border: 1px solid #ccc; box-shadow: none; }
      .toc { break-inside: avoid; box-shadow: none; }
      .table-section { break-inside: avoid-page; box-shadow: none; }
      .data-table thead th { background: #f0f0f0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .key-badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .back-top { display: none; }
      a { color: inherit; }
      .footer { break-before: avoid; }
    }

    @page { margin: 1.5cm; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="container" style="padding-top:0;padding-bottom:0;">
      <h1>{{projectName}}</h1>
      <div class="subtitle">Data Dictionary</div>
      <div class="header-meta">
        <span><span class="label">Connection:</span> {{connectionName}}</span>
        <span><span class="label">Database:</span> {{dbType}}</span>
        <span><span class="label">Version:</span> v{{version}}</span>
        <span><span class="label">Generated:</span> {{generatedAt}}</span>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- Stats -->
    <div class="stats-bar">
      <div class="stat-card">
        <div class="stat-value">{{tableCount}}</div>
        <div class="stat-label">Tables</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{{columnCount}}</div>
        <div class="stat-label">Columns</div>
      </div>
      {{#if procedureCount}}
      <div class="stat-card">
        <div class="stat-value">{{procedureCount}}</div>
        <div class="stat-label">Procedures</div>
      </div>
      {{/if}}
      <div class="stat-card">
        <div class="stat-value">v{{version}}</div>
        <div class="stat-label">Version</div>
      </div>
    </div>

    <!-- Table of Contents -->
    <div class="toc" id="toc">
      <h2>Table of Contents</h2>
      <div class="toc-grid">
        {{#each tables}}
        <div class="toc-item">
          <span class="toc-idx">{{inc @index}}</span>
          <a href="#table-{{@index}}">{{this.table_name}}</a>
          <span class="toc-cols">{{this.columnCount}} cols</span>
        </div>
        {{/each}}
      </div>
      {{#if procedures}}
      <h2 style="margin-top:14px;">Procedures</h2>
      <div class="toc-grid">
        {{#each procedures}}
        <div class="toc-item">
          <span class="toc-idx">{{inc @index}}</span>
          <a href="#proc-{{@index}}">{{this.procedure_name}}</a>
          <span class="toc-cols">{{this.procedure_type}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>

    <!-- Table Sections -->
    {{#each tables}}
    <div class="table-section" id="table-{{@index}}">
      <div class="table-header">
        <h3>{{this.table_name}}</h3>
        {{#if this.engine}}
        <span class="table-badge badge-engine">{{this.engine}}</span>
        {{/if}}
        {{#if this.row_count}}
        <span class="table-badge badge-rows">{{this.row_count}} rows</span>
        {{/if}}
        <a href="#toc" class="back-top">&uarr; Back to top</a>
        {{#if this.table_comment}}
        <div class="table-comment">{{this.table_comment}}</div>
        {{/if}}
        {{#if this.custom_comment}}
        <div class="table-comment custom">{{this.custom_comment}}</div>
        {{/if}}
      </div>

      <table class="data-table">
        <thead>
          <tr>
            <th style="width:36px;">#</th>
            <th>Column</th>
            <th>Type</th>
            <th>Nullable</th>
            <th>Key</th>
            <th>Default</th>
            <th>Extra</th>
            <th>Comment</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.columns}}
          <tr>
            <td style="color:#94a3b8;font-size:12px;">{{this.ordinal_position}}</td>
            <td class="col-name">{{this.column_name}}</td>
            <td class="col-type">{{this.column_type}}</td>
            <td class="col-nullable {{#ifEqual this.is_nullable 'YES'}}yes{{else}}no{{/ifEqual}}">
              {{this.is_nullable}}
            </td>
            <td>
              {{#ifEqual this.column_key 'PRI'}}<span class="key-badge key-pri">PK</span>{{/ifEqual}}
              {{#ifEqual this.column_key 'FK'}}<span class="key-badge key-foreign">FK</span>{{/ifEqual}}
              {{#ifEqual this.column_key 'UNI'}}<span class="key-badge key-uni">UNI</span>{{/ifEqual}}
              {{#ifEqual this.column_key 'MUL'}}<span class="key-badge key-mul">IDX</span>{{/ifEqual}}
            </td>
            <td class="col-default">{{#if this.column_default}}{{this.column_default}}{{else}}<span style="color:#cbd5e1;">NULL</span>{{/if}}</td>
            <td style="font-size:12px;color:#94a3b8;">{{this.extra}}</td>
            <td>
              {{#if this.column_comment}}<div class="col-comment">{{this.column_comment}}</div>{{/if}}
              {{#if this.custom_comment}}<div class="col-custom-comment">{{this.custom_comment}}</div>{{/if}}
              {{#each this.tags}}<span class="tag">{{this}}</span>{{/each}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      {{#if this.indexes}}
      <div class="indexes-section">
        <h4>Indexes ({{this.indexes.length}})</h4>
        {{#each this.indexes}}
        <div class="index-item">
          <span class="index-name">{{this.index_name}}</span>
          <span class="index-type">{{this.index_type}}</span>
          <span class="index-cols">{{#each this.columns}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
          {{#if this.is_unique}}<span class="index-unique">UNIQUE</span>{{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>
    {{/each}}

    {{#if procedures}}
    <h2 style="font-size:18px;font-weight:700;margin:32px 0 16px;color:var(--color-text);">Stored Procedures &amp; Functions</h2>
    {{#each procedures}}
    <div class="proc-section" id="proc-{{@index}}">
      <div class="proc-header">
        <h3>{{this.procedure_name}}</h3>
        {{#ifEqual this.procedure_type 'FUNCTION'}}
        <span class="table-badge badge-func">FUNCTION</span>
        {{else}}
        <span class="table-badge badge-proc">PROCEDURE</span>
        {{/ifEqual}}
        {{#if this.return_type}}
        <span class="proc-meta">returns <code>{{this.return_type}}</code></span>
        {{/if}}
        {{#if this.last_modified}}
        <span class="proc-meta">modified {{this.last_modified}}</span>
        {{/if}}
        <a href="#toc" class="back-top">&uarr; Back to top</a>
      </div>
      <div class="proc-body">
        {{#if this.procedure_comment}}
        <div class="table-comment">{{this.procedure_comment}}</div>
        {{/if}}
        {{#if this.custom_comment}}
        <div class="table-comment custom">{{this.custom_comment}}</div>
        {{/if}}

        {{#if this.parameters.length}}
        <h4>Parameters ({{this.parameters.length}})</h4>
        <table class="proc-params">
          <thead>
            <tr>
              <th style="width:60px;">Mode</th>
              <th>Name</th>
              <th>Type</th>
              <th>Default</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.parameters}}
            <tr>
              <td><span class="key-badge mode-{{this.mode}}">{{this.mode}}</span></td>
              <td class="col-name">{{this.name}}</td>
              <td class="col-type">{{this.type}}</td>
              <td class="col-default">{{#if this.default}}{{this.default}}{{else}}<span style="color:#cbd5e1;">—</span>{{/if}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}

        {{#if this.definition}}
        <h4>Definition</h4>
        <pre class="proc-definition">{{this.definition}}</pre>
        {{/if}}
      </div>
    </div>
    {{/each}}
    {{/if}}

    <!-- Footer -->
    <div class="footer">
      Generated by <strong>DBwiki</strong> &mdash; {{generatedAt}}
    </div>

  </div>

</body>
</html>
